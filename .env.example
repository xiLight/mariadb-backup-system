# MariaDB Configuration
MARIADB_ROOT_PASSWORD=your_secure_root_password_here
# Allow root login from outside the container ('yes'/'no').
# 'no' is more secure - admin then only via: docker exec / make mariadb
MARIADB_ROOT_REMOTE=yes
MARIADB_USER=app_user
MARIADB_PASSWORD=your_secure_app_password_here

# Database Names (you can configure 1-5 databases)
MARIADB_DATABASE1=myapp_db
MARIADB_DATABASE2=analytics_db
MARIADB_DATABASE3=logs_db
MARIADB_DATABASE4=cache_db
MARIADB_DATABASE5=backup_db

# Database Passwords
DATABASE1_PASSWORD=db1_password
DATABASE2_PASSWORD=db2_password
DATABASE3_PASSWORD=db3_password
DATABASE4_PASSWORD=db4_password
DATABASE5_PASSWORD=db5_password

# Container Configuration
# STACK_NAME prefixes all container/image names so multiple installations
# can coexist on one host (e.g. STACK_NAME=shop -> shop-node1, shop-haproxy)
STACK_NAME=mariadb
MARIADB_CONTAINER=mariadb
# Host port for MariaDB (single-node mode) - install.sh fills this via Portolan
MARIADB_PORT=3306
# Interface to publish the DB port on. 0.0.0.0 = all interfaces;
# use 127.0.0.1 if only local apps / a reverse proxy need access
MARIADB_BIND_IP=0.0.0.0

# Backup Configuration
BACKUP_DIR=./backups
BINLOG_DIR=./backups/binlogs

# Retention mode: 'generations' (keep last N fulls) or 'gfs'
# (grandfather-father-son: daily + weekly + monthly archives)
BACKUP_RETENTION_MODE=gfs
# generations mode: number of full backups to keep per database
BACKUP_KEEP_GENERATIONS=7
# gfs mode: how many daily / weekly / monthly archives to keep
BACKUP_KEEP_DAILY=7
BACKUP_KEEP_WEEKLY=4
BACKUP_KEEP_MONTHLY=12

# Offsite replication (offsite_sync.sh) - copies encrypted backups to a
# second host/storage. The encryption key is NEVER synced; store it
# separately (password manager / vault).
OFFSITE_METHOD=rsync
# rsync example: user@backuphost:/backups/mariadb | rclone example: remote:mariadb-backups
OFFSITE_TARGET=
# Run offsite sync automatically after every successful backup
OFFSITE_AUTO=no
# yes = mirror local retention to the remote (deletes remote files too)
OFFSITE_DELETE=no
# Encrypt binlogs before replicating them (binlog copies are plaintext locally)
OFFSITE_ENCRYPT_BINLOGS=yes
# Optional bandwidth limit (rsync: KB/s, rclone: e.g. 5M)
OFFSITE_BWLIMIT=

# Rolling logs: rotate when a log exceeds this size, keep this many rotated files
LOG_MAX_SIZE_KB=5120
LOG_KEEP=5
# Rotated logs older than this many days are deleted by log_cleanup.sh
LOG_RETENTION_DAYS=14

# Notifications (notify.sh) - all channels are optional, leave empty to disable
# ntfy topic URL, e.g. https://ntfy.sh/my-secret-topic
NOTIFY_NTFY_URL=
# Discord webhook URL
NOTIFY_DISCORD_WEBHOOK=
# Telegram bot token + chat id
NOTIFY_TELEGRAM_BOT_TOKEN=
NOTIFY_TELEGRAM_CHAT_ID=
# Heartbeat push URL (e.g. Uptime-Kuma) - pinged after every successful backup;
# your monitor alerts when the ping stays away
HEARTBEAT_URL=

# Timezone
TZ=Europe/Berlin

# Galera Cluster (only used with docker-compose.cluster.yml)
GALERA_CLUSTER_NAME=mariadb-galera
# Docker subnet for the cluster network - install.sh fills this via Portolan
GALERA_SUBNET=172.28.66.0/24
# State transfer method: mariabackup (donor stays writable) or
# rsync (no credentials needed - try this if joins keep failing)
GALERA_SST_METHOD=mariabackup
# Port HAProxy listens on for MariaDB traffic (automatic failover between nodes)
HAPROXY_PORT=3306
# Read-only port: round-robin over ALL nodes (SELECT-heavy workloads)
# TLS (after ./tls_setup.sh) works on the write AND read port - no extra port
HAPROXY_READ_PORT=3309
# HAProxy statistics dashboard port
HAPROXY_STATS_PORT=8404
# Stats page binding - localhost only by default (shows cluster internals);
# reach it remotely via SSH tunnel: ssh -L 8404:localhost:8404 server
HAPROXY_STATS_BIND_IP=127.0.0.1
# Seconds a node may take to resync during update/heal before giving up
CLUSTER_SYNC_TIMEOUT=600
# Check interval for ./heal.sh --daemon
HEAL_INTERVAL=30
